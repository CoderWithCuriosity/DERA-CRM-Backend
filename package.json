{
  "name": "dera-crm-backend",
  "version": "1.0.0",
  "description": "DERA CRM Backend API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:init": "ts-node scripts/run-migrations.ts",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:ordered": "ts-node scripts/run-seeders.ts",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:create": "npx sequelize-cli db:create",
    "db:drop": "npx sequelize-cli db:drop",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed",
    "db:refresh": "npm run db:migrate:undo:all && npm run db:migrate && npm run db:seed",
    "db:status": "npx sequelize-cli db:migrate:status",
    "db:menu": "ts-node scripts/run-migrations.ts",
    "db:generate:all": "node scripts/generate-migration-files.js",
    "create:admin": "ts-node scripts/createAdmin.ts",
    "backup": "ts-node scripts/backup.ts",
    "restore": "ts-node scripts/restore.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.1",
    "papaparse": "^5.4.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.6.5",
    "sequelize": "^6.32.1",
    "sharp": "^0.32.1",
    "uuid": "^9.0.0",
    "winston": "^3.9.0",
    "xlsx": "^0.18.5",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/ejs": "^3.1.2",
    "@types/express": "^4.17.17",
    "@types/json2csv": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.2.5",
    "@types/node-cron": "^3.0.7",
    "@types/nodemailer": "^6.4.8",
    "@types/papaparse": "^5.3.7",
    "@types/sequelize": "^4.28.14",
    "@types/uuid": "^9.0.1",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "eslint": "^8.41.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "sequelize-cli": "^6.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "crm",
    "api",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "Nwankwo Chidera David",
  "license": "MIT"
}