<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof subject !== 'undefined' ? subject : (typeof campaign_name !== 'undefined' ? campaign_name : '') %></title>
    <style>
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
        }
        
        .email-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 30px 20px;
            text-align: center;
            border-radius: 8px 8px 0 0;
        }
        
        .email-header h1 {
            color: white;
            margin: 0;
            font-size: 28px;
        }
        
        .email-content {
            background: white;
            padding: 30px;
            border: 1px solid #e0e0e0;
            border-top: none;
            border-radius: 0 0 8px 8px;
        }
        
        .email-footer {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: #999;
            border-top: 1px solid #eee;
            margin-top: 20px;
        }
        
        .button {
            display: inline-block;
            padding: 12px 24px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            margin: 20px 0;
        }
        
        .tracking-pixel {
            width: 1px;
            height: 1px;
            display: none;
        }
        
        @media only screen and (max-width: 600px) {
            .email-content {
                padding: 20px;
            }
            
            .email-header h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body style="margin: 0; padding: 20px; background-color: #f4f4f4;">
    <div class="email-container">
        <% if (typeof company_name !== 'undefined' && company_name) { %>
        <div class="email-header">
            <h1><%= company_name %></h1>
        </div>
        <% } %>
        
        <div class="email-content">
            <% if (typeof content !== 'undefined' && content) { %>
                <%- content %>
            <% } %>
        </div>
        
        <div class="email-footer">
            <p>&copy; <%= new Date().getFullYear() %> <% if (typeof company_name !== 'undefined' && company_name) { %><%= company_name %><% } else { %>DERA CRM<% } %>. All rights reserved.</p>
            <% if (typeof unsubscribe_link !== 'undefined' && unsubscribe_link && unsubscribe_link !== '#test-unsubscribe-link') { %>
            <p><a href="<%= unsubscribe_link %>" style="color: #999;">Unsubscribe</a></p>
            <% } %>
            <% if (typeof tracking_pixel !== 'undefined' && tracking_pixel && tracking_pixel !== '#test-tracking-pixel') { %>
            <img src="<%= tracking_pixel %>" alt="" class="tracking-pixel" />
            <% } %>
        </div>
    </div>
</body>
</html>